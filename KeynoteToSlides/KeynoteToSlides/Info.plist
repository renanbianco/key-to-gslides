    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.renanbianco.KeynoteToSlides.oauth</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>com.renanbianco.keynotetoslides</string>
            </array>
        </dict>
    </array>
